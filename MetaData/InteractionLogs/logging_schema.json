{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://studio.local/metadata/interaction-logging-schema.json",
  "title": "STUDIO Interaction Log Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "interaction_id",
    "mode",
    "timestamp",
    "model_name",
    "model_version",
    "prompt_text",
    "response_text",
    "prompt_token_count",
    "completion_token_count",
    "latency_ms",
    "workflow_version",
    "notes"
  ],
  "properties": {
    "interaction_id": {
      "type": "string",
      "description": "Unique identifier for a single interaction log entry.",
      "pattern": "^[a-zA-Z0-9._:-]+$"
    },
    "mode": {
      "type": "string",
      "enum": ["BUILD", "META", "RUN"],
      "description": "Execution mode declared at interaction start."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp for interaction completion in ISO 8601 format."
    },
    "model_name": {
      "type": "string",
      "minLength": 1
    },
    "model_version": {
      "type": "string",
      "minLength": 1
    },
    "prompt_text": {
      "type": "string",
      "minLength": 1
    },
    "response_text": {
      "type": "string",
      "minLength": 1
    },
    "prompt_token_count": {
      "type": "integer",
      "minimum": 0
    },
    "completion_token_count": {
      "type": "integer",
      "minimum": 0
    },
    "latency_ms": {
      "type": "integer",
      "minimum": 0
    },
    "workflow_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of STUDIO workflow definition used in this interaction."
    },
    "notes": {
      "type": "string"
    }
  }
}
